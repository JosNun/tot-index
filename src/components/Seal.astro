---
type Props = { size?: number; year?: number };
const { size = 80, year = 1953 } = Astro.props;
---
<div
  class="seal-ring relative flex items-center justify-center text-brown-deep"
  style={`width:${size}px;height:${size}px`}
  aria-hidden="true"
>
  <div class="absolute inset-[10%] rounded-full border-2 border-brown-deep flex flex-col items-center justify-center text-center leading-none">
    <span class="font-display uppercase tracking-[0.15em]" style={`font-size:${size * 0.13}px`}>
      Council
    </span>
    <span class="font-display font-bold" style={`font-size:${size * 0.22}px;line-height:1`}>
      {year}
    </span>
    <span class="font-display uppercase tracking-[0.15em]" style={`font-size:${size * 0.10}px`}>
      Established
    </span>
  </div>
</div>
